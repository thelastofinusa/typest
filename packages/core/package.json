{
  "name": "@typest/core",
  "version": "0.1.3",
  "private": false,
  "description": "Typed asset paths – core scanner & code generator",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist node_modules",
    "lint": "tsc --noEmit",
    "pushout": "npm publish --access public",
    "pushout-inc": "npm version patch --no-git-tag-version && pnpm pushout"
  },
  "dependencies": {
    "chokidar": "^5.0.0",
    "fast-glob": "^3.3.3"
  },
  "keywords": [
    "typed",
    "assets",
    "paths",
    "typescript"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^25.6.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
