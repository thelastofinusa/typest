{
  "name": "@typest/next",
  "version": "0.0.0",
  "type": "module",
  "description": "Next.js plugin for typed asset paths – autocomplete & type‑checking",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "typesVersions": {
    "*": {
      "*": [
        "../../../.assets/types.d.ts"
      ]
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@typest/core": "workspace:*"
  },
  "peerDependencies": {
    "next": ">=12.0.0"
  },
  "devDependencies": {
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "@types/node": "^25.6.0",
    "next": "^15.0.0"
  },
  "keywords": [
    "nextjs",
    "next.js",
    "plugin",
    "typed",
    "assets",
    "typescript"
  ],
  "license": "MIT"
}
