{
  "name": "@typest/cli",
  "version": "1.0.4",
  "type": "module",
  "description": "CLI to set up typed asset paths for Vite, Next.js, and more.",
  "bin": {
    "typest": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "homepage": "https://thetypest.vercel.app/plugin/cli.html",
  "repository": {
    "type": "git",
    "url": "https://github.com/thelastofinusa/typest.git",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/thelastofinusa/typest/issues"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist",
    "pushout": "npm publish --access public",
    "pushout-inc": "npm version patch --no-git-tag-version && pnpm pushout"
  },
  "dependencies": {
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "execa": "^9.6.1",
    "prompts": "^2.4.2",
    "ts-morph": "^28.0.0",
    "which-pm": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/prompts": "^2.4.9",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3"
  },
  "license": "MIT"
}
