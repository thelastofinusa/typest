{
  "name": "typest-monorepo",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "clean": "turbo run clean",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\"",
    "cli:dev": "pnpm build && clear && node packages/cli/dist/index.js",
    "cli:test:vite": "pnpm cli:dev --dir examples/vite-app",
    "cli:test:next": "pnpm cli:dev --dir examples/next-app"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "prettier": "^3.8.3",
    "turbo": "^2.9.6",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@9.1.0"
}
