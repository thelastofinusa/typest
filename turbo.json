{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".tsbuildinfo"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "test": {
      "dependsOn": ["build"],
      "inputs": ["src/**", "test/**", "vitest.config.ts"]
    },
    "@typest/web#build": {
      "outputs": [".vitepress/dist/**"]
    },
    "lint": {},
    "clean": {
      "cache": false
    }
  }
}
